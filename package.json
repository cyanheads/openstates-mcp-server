{
  "name": "openstates-mcp-server",
  "version": "0.1.1",
  "mcpName": "io.github.cyanheads/openstates-mcp-server",
  "description": "Search bills, legislators, committees, and events across all 50 US states, DC, and Puerto Rico via MCP. STDIO or Streamable HTTP.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openstates-mcp-server": "dist/index.js"
  },
  "files": [
    "changelog/",
    "dist/",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    "AGENTS.md",
    "Dockerfile",
    "server.json"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "rebuild": "tsx scripts/clean.ts && tsx scripts/build.ts",
    "clean": "tsx scripts/clean.ts",
    "devcheck": "tsx scripts/devcheck.ts",
    "audit:refresh": "rm -f bun.lock && bun install && bun audit",
    "tree": "tsx scripts/tree.ts",
    "list-skills": "tsx scripts/list-skills.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "tsx scripts/lint-mcp.ts",
    "lint:packaging": "tsx scripts/lint-packaging.ts",
    "bundle": "npm run build && npx -y @anthropic-ai/mcpb pack . dist/openstates-mcp-server.mcpb",
    "publish-mcp": "mcp-publisher login github -token \"$(security find-generic-password -a \"$USER\" -s mcp-publisher-github-pat -w)\" && mcp-publisher publish",
    "changelog:build": "tsx scripts/build-changelog.ts",
    "changelog:check": "tsx scripts/build-changelog.ts --check",
    "test": "vitest run",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "llm",
    "bun",
    "stdio",
    "streamable-http",
    "legislation",
    "openstates",
    "state-legislature",
    "bills",
    "legislators",
    "open-states"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/openstates-mcp-server.git"
  },
  "homepage": "https://github.com/cyanheads/openstates-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/openstates-mcp-server/issues"
  },
  "author": "Casey Hand <casey@caseyjhand.com> (https://github.com/cyanheads/openstates-mcp-server#readme)",
  "license": "Apache-2.0",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.9.7",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.6.0",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
